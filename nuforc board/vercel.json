{
  "framework": null,
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npx vite build --outDir ../public",
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...route]" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
